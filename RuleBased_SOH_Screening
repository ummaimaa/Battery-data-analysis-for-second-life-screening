fprintf('%-12s | %-8s | %-8s | %-12s | %-s\n', ...
'Battery','AvgSOH%','MinSOH%','MaxSOH%','Dominant Class');
fprintf('%s\n', repmat('-',1,70));

for b = 1:length(batteryNames)
bn = batteryNames{b};
idx = strcmp(featureTable.Battery, bn);
avgSOH = mean(featureTable.SOH_pct(idx),'omitnan');
