fprintf(' Avg SOH : %.1f%%\n', avgSOH);
switch classes(cl)
case "Good"
fprintf(' Condition : Battery health >= 80%%. Safe for primary use.\n');
case "Second-Life"
fprintf(' Condition : SOH 60-79%%. Viable for stationary storage or\n');
fprintf(' low-power 2nd life applications.\n');
case "Degraded"
fprintf(' Condition : SOH < 60%%. Significant capacity loss.\n');
fprintf(' Recommend retirement and recycling.\n');
end
end

fprintf('\n========================================\n\n');

%% =========================================================
%% 10. PER-BATTERY SOH REPORT
