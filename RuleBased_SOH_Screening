%% Rapid Second-Life Battery Screening - SOH Percentage Classification
% Good >= 80% | Second-Life: 60-79% | Degraded < 60%
% Run BatterySignalAnalysis.m first to generate allBatteries.mat

fprintf('\n=== Second-Life Battery SOH Screening ===\n');
fprintf('Classification: Good(>=80%%) | Second-Life(60-79%%) | Degraded(<60%%)\n\n');

%% 1. Load Battery Structure
if ~exist('allBatteries.mat','file')
error('allBatteries.mat not found. Run BatterySignalAnalysis.m first.');
end

load('allBatteries.mat'); % loads allBatteries and cycleTypeSummary
batteryNames = fieldnames(allBatteries);

%% 2. Create Folder for Results
resultsDir = 'FeatureResults';
if ~exist(resultsDir,'dir')
mkdir(resultsDir);
end

%% 3. Parameters
Fs = 1;
segmentLength = 120;
segmentStep = 60;
band = [0.05 0.2];

featureTable = [];

fprintf('Extracting TF Features from Discharge Cycles...\n\n');

%% 4. Loop Through Batteries and Discharge Cycles
for b = 1:length(batteryNames)
batteryName = batteryNames{b};
cycles = allBatteries.(batteryName).cycle;
fprintf(' Processing %s (%d total cycles)...\n', batteryName, length(cycles));
nDischarge = 0;
for c = 1:length(cycles)
if ~strcmp(lower(cycles(c).type),'discharge')
continue;
end
nDischarge = nDischarge + 1;
data = cycles(c).data;
rawTime = data.Time;
rawVoltage = data.Voltage_measured;
rawCurrent = data.Current_measured;
%% --- Resample ---
tUniform = (0:1:max(rawTime))';
vUniform = interp1(rawTime, rawVoltage, tUniform, 'pchip');
%% --- Sliding Window Segments ---
N = length(tUniform);
segStart = 1:segmentStep:(N - segmentLength);
for s = 1:length(segStart)
idx1 = segStart(s);
idx2 = idx1 + segmentLength - 1;
vSeg = detrend(vUniform(idx1:idx2));
%% --- STFT ---
window = 64;
noverlap = 32;
nfft = 128;
[~, F, ~, P] = spectrogram(vSeg, window, noverlap, nfft, Fs);
%% --- Feature 1: Band Energy ---
bandIdx = F >= band(1) & F <= band(2);
bandEnergy = mean(sum(P(bandIdx,:),1));
%% --- Feature 2: Spectral Centroid ---
specPower = mean(P,2);
spectralCentroid = sum(F .* specPower) / sum(specPower);
%% --- Feature 3: Spectral Entropy ---
p = specPower ./ sum(specPower);
spectralEntropy = -sum(p .* log2(p + eps));
%% --- Capacity ---
capacity = NaN;
if isfield(data,'Capacity')
cap = data.Capacity;
if isnumeric(cap) && ~isempty(cap)
capacity = cap(1);
end
end
%% --- Store Row ---
featureTable = [featureTable;
{batteryName, c, nDischarge, bandEnergy, ...
spectralCentroid, spectralEntropy, capacity}];
end
end
fprintf(' -> %d discharge cycles processed.\n', nDischarge);
end

%% 5. Convert to Table
featureTable = cell2table(featureTable, ...
'VariableNames',{'Battery','CycleIndex','DischargeNumber', ...
'BandEnergy','SpectralCentroid','SpectralEntropy','Capacity'});

fprintf('\nTotal Segments Analysed: %d\n', height(featureTable));

%% 5.1 Ensure Numeric Columns
numericCols = {'BandEnergy','SpectralCentroid','SpectralEntropy','Capacity'};

for nc = 1:length(numericCols)
col = numericCols{nc};
if iscell(featureTable.(col))
tmp = nan(height(featureTable),1);
for i = 1:height(featureTable)
v = featureTable.(col){i};
if isnumeric(v) && ~isempty(v)
tmp(i) = v(1);
end
end
featureTable.(col) = tmp;
end
end

%% =========================================================
%% 6. SOH PERCENTAGE ESTIMATION
%% =========================================================
%
% Strategy:
% - Use Capacity directly when available (most reliable)
% - Fall back to Band Energy when Capacity is missing
%
% Reference capacity (nominal for NASA dataset): ~2.0 Ah
% SOH(%) = (Current Capacity / Nominal Capacity) x 100
%
% When using Band Energy (proxy):
% - Normalise band energy to [0,1] range
% - Map to SOH range [30%, 100%] (realistic degradation window)

NOMINAL_CAPACITY = 2.0; % Ah (NASA dataset nominal)
SOH_MIN_PROXY = 30; % % floor when using energy proxy
SOH_MAX_PROXY = 100; % % ceiling when using energy proxy

fprintf('\nEstimating SOH Percentage...\n');

nRows = height(featureTable);
SOH = nan(nRows,1);
SOH_source = strings(nRows,1);

%% --- Per-battery energy min/max for normalisation ---
for b = 1:length(batteryNames)
bn = batteryNames{b};
idx = strcmp(featureTable.Battery, bn);
e = featureTable.BandEnergy(idx);
eMin = min(e); eMax = max(e);
capVals = featureTable.Capacity(idx);
hasCapacity = ~isnan(capVals);
rows = find(idx);
for r = 1:length(rows)
ri = rows(r);
if ~isnan(featureTable.Capacity(ri))
% --- Direct capacity-based SOH ---
SOH(ri) = (featureTable.Capacity(ri) / NOMINAL_CAPACITY) * 100;
SOH(ri) = min(max(SOH(ri), 0), 100); % clamp
SOH_source(ri) = "Capacity";
else
% --- Proxy via band energy ---
if eMax > eMin
eNorm = (featureTable.BandEnergy(ri) - eMin) / (eMax - eMin);
else
eNorm = 0.5;
end
SOH(ri) = SOH_MIN_PROXY + eNorm * (SOH_MAX_PROXY - SOH_MIN_PROXY);
SOH_source(ri) = "EnergyProxy";
end
end
end

featureTable.SOH_pct = SOH;
featureTable.SOH_source = SOH_source;

%% =========================================================
%% 7. PERCENTAGE-BASED CLASSIFICATION
%% =========================================================
%
% Good >= 80% --> Healthy, no second-life needed
% Second-Life 60-79% --> Suitable for second-life applications
% Degraded < 60% --> End of life, retire or recycle

fprintf('Applying Percentage-Based Classification...\n');

classLabel = strings(nRows,1);
recommendation = strings(nRows,1);

for i = 1:nRows
soh = featureTable.SOH_pct(i);
if soh >= 80
classLabel(i) = "Good";
recommendation(i) = "Continue Primary Use";
elseif soh >= 60
classLabel(i) = "Second-Life";
recommendation(i) = "Repurpose for 2nd Life";
else
classLabel(i) = "Degraded";
recommendation(i) = "Retire / Recycle";
end
end

featureTable.Class = classLabel;
featureTable.Recommendation = recommendation;

%% 8. Confidence Score (distance from nearest boundary)
confidence = zeros(nRows,1);
for i = 1:nRows
soh = featureTable.SOH_pct(i);
dist80 = abs(soh - 80);
dist60 = abs(soh - 60);
minDist = min(dist80, dist60);
confidence(i) = min(minDist / 20, 1.0); % normalise to [0,1]
end
featureTable.Confidence = confidence;

%% =========================================================
%% 9. SUMMARY STATISTICS
%% =========================================================

fprintf('\n========================================\n');
fprintf(' SOH CLASSIFICATION SUMMARY\n');
fprintf('========================================\n');

classes = ["Good","Second-Life","Degraded"];
classColors = {'g','y','r'};

for cl = 1:3
